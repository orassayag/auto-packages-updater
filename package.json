{
  "name": "auto-packages-updater",
  "version": "1.0.0",
  "private": false,
  "description": "A Node.js automation tool for scanning multiple projects for outdated npm packages and updating them with Git integration. Reads project configurations from external JSON files, checks dependencies across projects, generates reports, and optionally updates packages in local and Git repositories",
  "keywords": [
    "node",
    "nodejs",
    "npm",
    "packages",
    "updater",
    "automation",
    "outdated",
    "update",
    "git",
    "github",
    "multi-project",
    "dependency-management",
    "npm-check-updates",
    "package-manager",
    "devops",
    "automation-tool"
  ],
  "homepage": "https://github.com/orassayag/auto-packages-updater#readme",
  "bugs": {
    "url": "https://github.com/orassayag/auto-packages-updater/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/auto-packages-updater.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/orassayag"
  },
  "license": "MIT",
  "author": {
    "name": "Or Assayag",
    "email": "orassayag@gmail.com",
    "url": "https://github.com/orassayag"
  },
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "type": "module",
  "main": "src/scripts/packages.script.js",
  "files": [
    ".github",
    ".vscode",
    "dist",
    "misc",
    "sources",
    "src",
    ".eslintignore",
    ".eslintrc",
    ".gitignore",
    ".jsbeautifyrc",
    ".npmignore",
    ".prettierrc",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "eslint.config.mjs",
    "INSTRUCTIONS.md",
    "knip.json",
    "LICENSE",
    "package-lock.json",
    "package.json",
    "pnpm-lock.yaml",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "backup": "node src/scripts/backup.script.js",
    "sand": "node src/tests/sandBox.test.js",
    "start": "node src/scripts/packages.script.js",
    "stop": "taskkill -f -im node.exe"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "dependencies": {
    "fs-extra": "^11.3.5",
    "is-reachable": "^6.1.0",
    "npm-check-updates": "^22.2.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "eslint": "^10.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
